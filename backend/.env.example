# ============================================
# ENTORNO
# ============================================
# production | development. Controla logging, seed endpoints y fallbacks de seguridad
ENVIRONMENT=development

# Puerto del servidor (Railway lo inyecta automáticamente en prod)
PORT=8000

# ============================================
# BASE DE DATOS
# ============================================
# Local: SQLite. Producción: Railway inyecta postgresql://
# NUNCA usar postgres.railway.internal en local
DATABASE_URL=sqlite:///./dazz_producciones.db

# ============================================
# AUTENTICACIÓN JWT
# ============================================
# OBLIGATORIO. Min 32 chars. Genera con: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-secure-random-string-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# ENCRIPTACIÓN (IBAN Fernet AES-128)
# ============================================
# OBLIGATORIO en producción. Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-fernet-base64-key

# ============================================
# AI — Claude (Anthropic)
# ============================================
# Extracción de tickets y validación de facturas/certificados bancarios
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# EMAIL (Brevo API — NO SMTP, Railway bloquea puerto 587)
# ============================================
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=aibot2@dazzcreative.com
FROM_NAME=DAZZ Creative
FRONTEND_URL=https://dazz-producciones.vercel.app

# ============================================
# PORTAL PROVEEDORES
# ============================================
SUPPLIER_PORTAL_URL=https://providers.dazzcreative.com
ADMIN_NOTIFICATION_EMAIL=admin@dazzcreative.com

# ============================================
# STORAGE — Cloudinary (PDFs de facturas de proveedores)
# ============================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# RATE LIMITING — Upstash Redis (free tier: 500K commands/month, single URL works local + Railway)
# Si no se configura: fallback a memory:// con warning (NO comparte contadores entre workers)
# Formato: rediss://default:TOKEN@HOST.upstash.io:6379  (doble 's' = TLS)
# ============================================
REDIS_URL=rediss://default:your-token@your-endpoint.upstash.io:6379

# ============================================
# STORAGE — Cloudflare R2 (certificados bancarios privados, signed URLs 15min)
# ============================================
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=bank-certs
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
